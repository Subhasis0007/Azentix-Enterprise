# .env.example - copy to .env and fill in real values
# Run: cp .env.example .env then fill in each value

# AZURE OPENAI (only paid service, $200 free credit)
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your_key_here
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o-mini

# SUPABASE (replaces Cosmos DB - free forever )
SUPABASE_URL=https://xxxxxxx.supabase.com
SUPABASE_ANON_KEY = eyfjy
SUPABASE_SERVICE_KEY= eyhjj
SUPABASE_DB_CONNECTION=postgresql://postgresql:PASSWORD@db.xxx.supabase.co:5432/postgres

#CLOUDAMQP RABBITMQ (replaces Azure Service Bus - free 1M/month)
CLOUDAMQP_URL=amqps://user:password@host/vhost
RABBITMQ_QUEUE_SAP_PRICES=
RABBITMQ_QUEUE_INCIDENTS=
RABBITMQ_QUEUE_STRIPE=
RABBITMQ_QUEUE_HUBSPOT=
RABBITMQ_QUEUE_APPROVAL=
RABBITMQ_QUEUE_NOTIFICATIONS=

# N8N (replaces azure Logic Apps  - free-self-hosted)
N8N_URL=https://your-n8n.onrender.com
N8N_WEBHOOK_BASE=
N8N_BASIC_AUTH_USER=
N8N_BASIC_AUTH_PASSWORD=

# KONG GATEWAY (REPLACES AZURE APIM - free open source)
KONG_PROXY_URL=https://localhost:8000
KONG_ADMIN_URL=
KONG_API_KEY_AZENTIX=

# render.com (replaces Azure App Service - free tier)
GRAFAN_PROMETHEUS_URL=
GRAFANA_PROMETHEUS_USER=
GRAFANA_API_KEY=
GRAFANA_LOKI_URL=
GRAFANA_LOKI_USER=

# SAP (FREE SANDBOX AT API.SAP.COM)
SAP_BASE_URL=
SAP_API_KEY=
SAP_SYSTEM=
SAP_DEFAULT_SALES_ORG=

# SALESFORCE (developer ediotion free forever)
SALESFORCE_INSTANCE_URL=
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
SALESFORCE_USERNAME=
SALESFORCE_PASSWORD=
SALESFORCE_API_VERSION=

# SERVICENOW (PDI -FREE FOREVER)
SERVICENOW_INSTANCE_URL=
SERVICENOW_USERNAME=
SERVICENOW_PASSWORD=

# HUBSPOT (FREE CRM TIER)
HUBSPOT_ACCESS_TOKEN=
HUBSPOT_PORTAL_ID=
HUBSPOT_API_BASE=

# STRIPE(TEST MODE - FREE)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_API_VERSION=