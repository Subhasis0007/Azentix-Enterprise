# Copy to .env and fill in real values — NEVER commit .env

# Azure OpenAI (only paid service — $200 free credit)
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your_key_here
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o-mini
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# Supabase (replaces Cosmos DB — free forever)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGci...
SUPABASE_SERVICE_KEY=eyJhbGci...
SUPABASE_DB_CONNECTION=postgresql://postgres:PASSWORD@db.xxx.supabase.co:5432/postgres

# CloudAMQP RabbitMQ (replaces Azure Service Bus — free 1M/month)
CLOUDAMQP_URL=amqps://user:password@host/vhost
RABBITMQ_QUEUE_SAP_PRICES=sap-price-changes
RABBITMQ_QUEUE_INCIDENTS=servicenow-incidents
RABBITMQ_QUEUE_STRIPE=stripe-events
RABBITMQ_QUEUE_HUBSPOT=hubspot-sync
RABBITMQ_QUEUE_APPROVAL=approval-queue
RABBITMQ_QUEUE_NOTIFICATIONS=notifications

# n8n (replaces Logic Apps — free self-hosted)
N8N_URL=https://your-n8n.onrender.com
N8N_WEBHOOK_BASE=https://your-n8n.onrender.com/webhook
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=your_n8n_password

# Kong Gateway (replaces APIM — free open source)
KONG_PROXY_URL=http://localhost:8000
KONG_ADMIN_URL=http://localhost:8001
KONG_API_KEY_AZENTIX=azentix-internal-key-change-this

# Render.com (replaces Azure App Service)
RENDER_APP_URL=https://azentix-agent-host.onrender.com

# Grafana Cloud (replaces App Insights — free 50GB logs)
GRAFANA_PROMETHEUS_URL=https://prometheus-prod-xx.grafana.net/api/prom
GRAFANA_PROMETHEUS_USER=123456
GRAFANA_API_KEY=glc_your_api_key
GRAFANA_LOKI_URL=https://logs-prod-xx.grafana.net/loki/api/v1/push
GRAFANA_LOKI_USER=456789

# SAP (free sandbox — api.sap.com)
SAP_BASE_URL=https://sandbox.api.sap.com/s4hanacloud
SAP_API_KEY=your_sap_api_key
SAP_SYSTEM=SANDBOX
SAP_DEFAULT_SALES_ORG=GB01

# Salesforce Developer Edition (free forever)
SALESFORCE_INSTANCE_URL=https://yourorg.my.salesforce.com
SALESFORCE_CLIENT_ID=your_consumer_key
SALESFORCE_CLIENT_SECRET=your_consumer_secret
SALESFORCE_USERNAME=your@email.com
SALESFORCE_PASSWORD=YourPasswordPlusSecurityToken
SALESFORCE_API_VERSION=v59.0

# ServiceNow PDI (free forever)
SERVICENOW_INSTANCE_URL=https://devXXXXX.service-now.com
SERVICENOW_USERNAME=admin
SERVICENOW_PASSWORD=your_admin_password

# HubSpot Free CRM
HUBSPOT_ACCESS_TOKEN=pat-na1-your_private_app_token
HUBSPOT_PORTAL_ID=your_hub_id
HUBSPOT_API_BASE=https://api.hubapi.com

# Stripe Test Mode (free)
STRIPE_SECRET_KEY=sk_test_your_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_secret
STRIPE_API_VERSION=2024-06-20

# Agent tuning
AGENT_MAX_ITERATIONS=10
AGENT_TIMEOUT_SECONDS=60
AGENT_MAX_TOKENS=2000
AGENT_TOKEN_BUDGET=16000
