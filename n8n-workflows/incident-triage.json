{
  "name": "Azentix — ServiceNow Incident Triage",
  "active": false,
  "nodes": [
    {
      "parameters": { "queue": "servicenow-incidents", "options": { "contentIsJson": true } },
      "name": "1_RabbitMQ_Trigger", "type": "n8n-nodes-base.rabbitMq",
      "typeVersion": 1, "position": [200, 300],
      "credentials": { "rabbitmq": { "id": "1", "name": "CloudAMQP" } }
    },
    {
      "parameters": {
        "url": "={{ $env.KONG_PROXY_URL }}/azentix/v1/agents/execute",
        "method": "POST",
        "sendHeaders": true,
        "headerParameters": { "parameters": [
          { "name": "Content-Type", "value": "application/json" },
          { "name": "X-API-Key",   "value": "={{ $env.KONG_API_KEY_AZENTIX }}" }
        ]},
        "sendBody": true, "contentType": "raw", "rawContentType": "application/json",
        "body": "={{ JSON.stringify({ taskType: 'servicenow-incident-triage', priority: 'High', description: 'Triage ServiceNow incident ' + $json.incidentNumber, inputData: { incidentNumber: $json.incidentNumber }, context: 'Auto-classify, search KB, route P3/P4 or escalate P1/P2.' }) }}",
        "options": { "timeout": 120000 }
      },
      "name": "2_Triage_Agent", "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4, "position": [440, 300]
    },
    {
      "parameters": { "queue": "notifications", "message": "={{ JSON.stringify({ type: 'incident_triaged', incident: $('1_RabbitMQ_Trigger').item.json.incidentNumber, status: $json.status, answer: $json.finalAnswer }) }}" },
      "name": "3_Notify", "type": "n8n-nodes-base.rabbitMq", "position": [680, 300],
      "credentials": { "rabbitmq": { "id": "1", "name": "CloudAMQP" } }
    }
  ],
  "connections": {
    "1_RabbitMQ_Trigger": { "main": [[{ "node": "2_Triage_Agent", "type": "main", "index": 0 }]] },
    "2_Triage_Agent":     { "main": [[{ "node": "3_Notify",        "type": "main", "index": 0 }]] }
  }
}
